@page "/nueva-marca"
@using PruebaTecnicaFinanzauto.Models
@using PruebaTecnicaFinanzauto.Service
@inject MarcaService MarcaService

<h3>Registrar Marca</h3>

@if (mensaje != null)
{
    <div class="alert @(esError ? "alert-danger" : "alert-success")">@mensaje</div>
}

<div class="mb-3">
    <label>Nombre:</label>
    <input @bind="nuevaMarca.Nombre" class="form-control" placeholder="Ej: Toyota" />
</div>
<div class="mb-3">
    <label>País de Origen:</label>
    <input @bind="nuevaMarca.PaisOrigen" class="form-control" placeholder="Ej: Japón" />
</div>
<div class="mb-3">
    <label>Descripción (opcional):</label>
    <input @bind="nuevaMarca.Descripcion" class="form-control" />
</div>
<button class="btn btn-primary" @onclick="CrearMarca" disabled="@cargando">
    @(cargando ? "Guardando..." : "Crear Marca")
</button>

@code {
    private Marcas nuevaMarca = new();
    private string? mensaje;
    private bool esError;
    private bool cargando;

    private async Task CrearMarca()
    {
        cargando = true;
        mensaje = null;
        try
        {
            await MarcaService.CrearMarcas(nuevaMarca);
            mensaje = $"Marca '{nuevaMarca.Nombre}' creada exitosamente.";
            esError = false;
            nuevaMarca = new();
        }
        catch (Exception ex)
        {
            mensaje = ex.Message;
            esError = true;
        }
        finally { cargando = false; }
    }
}