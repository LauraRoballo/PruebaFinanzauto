@page "/editar-vendedor"
@using PruebaTecnicaFinanzauto.Models
@using PruebaTecnicaFinanzauto.Models.DTOs
@using PruebaTecnicaFinanzauto.Service
@inject VendedorService VendedorService

<h3>Actualizar Vendedor</h3>

<div class="mb-3">
    <label>Cédula del Vendedor:</label>
    <div class="d-flex gap-2">
        @* Usamos @bind:event="oninput" para que sea más fluido si lo deseas *@
        <input @bind="cedulaBusqueda" class="form-control" placeholder="Ej: 123456" />
        <button class="btn btn-primary" @onclick="BuscarVendedor">Buscar</button>
    </div>
</div>

@if (vendedor != null)
{
    <div class="card p-3 shadow-sm">
        <div class="mb-3">
            <label>Nombre:</label>
            <input @bind="vendedor.Nombre" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Apellido:</label>
            <input @bind="vendedor.Apellido" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Cédula (Actual):</label>
            <input @bind="vendedor.Cedula" class="form-control" />
        </div>
        <button class="btn btn-success" @onclick="GuardarCambios">Guardar Cambios</button>
    </div>
}

@code {
    // Inicializamos con valores vacíos para evitar advertencias CS8618
    private string cedulaBusqueda = "";
    private Vendedores? vendedor;

    private async Task BuscarVendedor()
    {
        try
        {
            // Buscamos al vendedor por la cédula ingresada
            vendedor = await VendedorService.ObtenerPorCedula(cedulaBusqueda);
        }
        catch (Exception ex)
        {
            // Si no existe o hay error, limpiamos la vista
            vendedor = null;
            Console.WriteLine($"Error al buscar: {ex.Message}");
        }
    }

    private async Task GuardarCambios()
    {
        if (vendedor != null)
        {
            try
            {
                // Creamos el DTO con los datos del formulario
                var dto = new ActualizarVendedorDto
                {
                    Nombre = vendedor.Nombre,
                    Apellido = vendedor.Apellido,
                    Cedula = vendedor.Cedula
                };
                
                // Enviamos la cédula original y el DTO al servicio
                await VendedorService.ActualizarVendedor(cedulaBusqueda, dto);
                
                // Opcional: podrías mostrar una alerta de éxito aquí
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al guardar: {ex.Message}");
            }
        }
    }
}