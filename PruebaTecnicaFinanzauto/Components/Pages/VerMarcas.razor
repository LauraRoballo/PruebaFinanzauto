@page "/marcas"
@using PruebaTecnicaFinanzauto.Models
@using PruebaTecnicaFinanzauto.Service
@inject MarcaService MarcaService

<h3>Marcas</h3>

@if (mensaje != null)
{
    <div class="alert @(esError ? "alert-danger" : "alert-success")">@mensaje</div>
}

<table class="table table-striped">
    <thead>
        <tr><th>Nombre</th><th>País</th><th>Descripción</th><th>Acción</th></tr>
    </thead>
    <tbody>
        @foreach (var m in lista)
        {
            <tr>
                <td>@m.Nombre</td>
                <td>@m.PaisOrigen</td>
                <td>@m.Descripcion</td>
                <td>
                    <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(m.Nombre)">
                        Eliminar
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Marcas> lista = new();
    private string? mensaje;
    private bool esError;

    protected override void OnInitialized()
    {
        lista = MarcaService.ObtenerMarcas();
    }

    private void Eliminar(string nombre)
    {
        try
        {
            MarcaService.EliminarMarca(nombre);
            mensaje = $"Marca '{nombre}' eliminada."; esError = false;
            lista = MarcaService.ObtenerMarcas();
        }
        catch (Exception ex) { mensaje = ex.Message; esError = true; }
    }
}